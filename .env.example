# ─── Entorno ───────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info

# ─── Control plane (API + WebSocket) ─────────────────────────────────────────
API_PORT=8080
WS_PORT=8081
# Origen permitido del frontend (CORS)
FRONTEND_ORIGIN=http://localhost:5173

# ─── Base de datos (PostgreSQL / Prisma) ─────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rpa?schema=public

# ─── Almacén de estado de jobs / señal human-in-the-loop ─────────────────────
# Backend del store: "memory" (solo dev) | "dynamo"
STATE_BACKEND=memory
STATE_TABLE=extraction_jobs
AWS_REGION=eu-west-1

# ─── S3 (documentos) ─────────────────────────────────────────────────────────
DOCS_BUCKET=finidian-rpa-docs
DOCS_KMS_KEY_ID=alias/rpa-docs

# ─── Proxy residencial rotativo (IP España) ──────────────────────────────────
# Server del gateway del proveedor (Bright Data / Oxylabs / SOAX)
PROXY_SERVER=http://gw.proxyprovider.io:7000
PROXY_USERNAME=customer-XXXX
PROXY_PASSWORD=__secret__
# Plantilla de username con placeholders {country} y {session} (sticky por job)
PROXY_USERNAME_TEMPLATE=customer-XXXX-country-{country}-session-{session}
PROXY_COUNTRY=es

# ─── Playwright ──────────────────────────────────────────────────────────────
HEADLESS=true
# User-Agent realista de Chrome estable (NO el de Playwright)
BROWSER_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/127.0.0.0 Safari/537.36
# Ventana de validación Cl@ve Móvil en ms (timer ~1:20 → margen a 95s)
CLAVE_GATE_TIMEOUT_MS=95000
# Vida máxima absoluta de un job antes de matar la task (anti-zombi)
JOB_MAX_LIFETIME_MS=480000

# ─── Orquestación human-in-the-loop ──────────────────────────────────────────
# "poll" (worker consulta el store) | "stepfunctions" (SendTaskSuccess)
HUMAN_GATE_MODE=poll

# ─── Comunicación worker → control-plane ─────────────────────────────────────
CONTROL_PLANE_URL=http://localhost:8080
INTERNAL_API_TOKEN=dev-internal-token
# Parámetros del job (los inyecta ECS RunTask como override; en local, JSON):
# JOB_PARAMS={"jobId":"...","userId":"...","docType":"VIDA_LABORAL"}

# ─── Lanzamiento del worker desde el control-plane ───────────────────────────
# "inline" (mismo proceso, demo offline) | "local" (spawn) | "ecs" (RunTask Fargate)
WORKER_LAUNCH_MODE=local
ECS_CLUSTER=rpa-espana
ECS_TASK_DEFINITION=rpa-worker:1
ECS_CONTAINER_NAME=worker
ECS_SUBNETS=subnet-aaa,subnet-bbb
ECS_SECURITY_GROUPS=sg-worker

# ─── Demo offline (probar el flujo sin sedes reales ni AWS) ──────────────────
# Para una demo end-to-end local: WORKER_LAUNCH_MODE=inline + DEV_FAKE_SCRAPE=true
DEV_FAKE_SCRAPE=false
DEV_SKIP_S3=false
