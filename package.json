{
  "name": "rpa-espana",
  "version": "0.1.0",
  "private": true,
  "description": "RPA in-house para extracción de documentos financieros oficiales (AEAT / TGSS) con Cl@ve Móvil y validación human-in-the-loop.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev:api": "tsx watch src/control-plane/index.ts",
    "dev:worker": "tsx src/worker/index.ts",
    "start:api": "node dist/control-plane/index.js",
    "start:worker": "node dist/worker/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.620.0",
    "@aws-sdk/client-ecs": "^3.620.0",
    "@aws-sdk/client-s3": "^3.620.0",
    "@aws-sdk/client-sfn": "^3.620.0",
    "@aws-sdk/lib-dynamodb": "^3.620.0",
    "@aws-sdk/lib-storage": "^3.620.0",
    "@aws-sdk/s3-request-presigner": "^3.620.0",
    "@prisma/client": "^5.18.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "pino": "^9.3.2",
    "playwright": "^1.48.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "ulid": "^2.3.0",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/ws": "^8.5.12",
    "prisma": "^5.18.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
